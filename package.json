{
  "name": "@designsetgo/app-client",
  "version": "0.1.0",
  "description": "Bridge client for DesignSetGo Apps — typed dsgo namespace for apps running inside the WP iframe runtime.",
  "license": "GPL-2.0-or-later",
  "type": "module",
  "main": "dist/client.cjs",
  "module": "dist/client.mjs",
  "types": "dist/client.d.ts",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rollup -c",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "^22.0.0",
    "jsdom": "^25.0.0",
    "rollup": "^4.20.0",
    "rollup-plugin-dts": "^6.1.0",
    "tslib": "^2.7.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
